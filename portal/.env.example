# Portal Sparkle AI — Variáveis de Ambiente
# Copiar para .env.local e preencher os valores reais.
# NUNCA commitar .env.local — já está no .gitignore.

# ── Supabase (acesso público — usado pelo cliente browser se necessário) ──
NEXT_PUBLIC_SUPABASE_URL=https://gqhdspayjtiijcqklbys.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Supabase Server (service_role) ── NUNCA usar prefixo NEXT_PUBLIC_ aqui ──
# Usada exclusivamente em API routes (supabase-server.ts) e middleware
SUPABASE_URL=https://gqhdspayjtiijcqklbys.supabase.co
SUPABASE_SERVICE_KEY=   # <-- Pegar no Supabase Dashboard > Settings > API > service_role key

# ── App ──
NEXT_PUBLIC_APP_URL=https://portal.sparkleai.tech   # usar http://localhost:3000 em dev
